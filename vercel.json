{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.{html,css,js}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/admin", "dest": "admin.html" },
    { "src": "/(.*\\.(css|js|html|ico|png|jpg|svg|woff2?))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}