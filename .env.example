# Environment Configuration
# Copy this file to .env and update values as needed

# ═════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════════

# Port for the Express server
PORT=3000

# Node environment
NODE_ENV=development

# ═════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═════════════════════════════════════════════════════════

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/streamingDB

# Database name (if not using full URI)
DB_NAME=streamingDB

# Database host
DB_HOST=127.0.0.1

# Database port
DB_PORT=27017

# ═════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═════════════════════════════════════════════════════════

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ═════════════════════════════════════════════════════════
# API CONFIGURATION
# ═════════════════════════════════════════════════════════

# Frontend API base URL (used in browser)
API_BASE=http://localhost:3000/api

# ═════════════════════════════════════════════════════════
# FILE UPLOAD CONFIGURATION
# ═════════════════════════════════════════════════════════

# Max file size for uploads (in bytes)
MAX_FILE_SIZE=52428800

# Allowed file types for videos
ALLOWED_VIDEO_TYPES=.mp4,.webm,.mkv,.avi

# ═════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═════════════════════════════════════════════════════════

# Logging level: error, warn, info, debug, trace
LOG_LEVEL=info

# ═════════════════════════════════════════════════════════
# SECURITY CONFIGURATION (Future)
# ═════════════════════════════════════════════════════════

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_key_here

# JWT Expiration
JWT_EXPIRATION=7d

# ═════════════════════════════════════════════════════════
# PRODUCTION SETTINGS
# ═════════════════════════════════════════════════════════

# Enable HTTPS
ENABLE_HTTPS=false

# SSL Certificate path
SSL_CERT_PATH=/path/to/cert.pem

# SSL Key path
SSL_KEY_PATH=/path/to/key.pem

# ═════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═════════════════════════════════════════════════════════

# Enable user authentication
ENABLE_AUTH=false

# Enable analytics
ENABLE_ANALYTICS=false

# Enable caching
ENABLE_CACHING=true

# ═════════════════════════════════════════════════════════
# NOTES
# ═════════════════════════════════════════════════════════

# Development settings (defaults):
#   PORT=3000
#   NODE_ENV=development
#   MONGODB_URI=mongodb://127.0.0.1:27017/streamingDB
#   These are suitable for local development

# For production, set:
#   NODE_ENV=production
#   Use a managed MongoDB service (MongoDB Atlas, etc.)
#   Enable HTTPS
#   Set strong JWT_SECRET
#   Configure proper CORS_ORIGIN
